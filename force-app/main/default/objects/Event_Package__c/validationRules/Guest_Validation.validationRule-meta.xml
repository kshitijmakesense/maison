<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Guest_Validation</fullName>
    <active>true</active>
    <errorConditionFormula>Minimum_Guests__c &gt; Maximum_Guests__c</errorConditionFormula>
    <errorMessage>The maximum number of guests must be greater than minimum number of guests.</errorMessage>
</ValidationRule>
