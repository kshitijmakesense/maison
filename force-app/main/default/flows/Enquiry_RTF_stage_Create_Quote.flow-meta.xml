<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Quote_creation_requested_in_Quotient_checked</name>
        <label>Quote creation requested in Quotient checked</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>$Record.Quote_creation_requested_in_Quotient__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
    </assignments>
    <assignments>
        <name>Quote_creation_requested_in_Quotient_unchecked</name>
        <label>Quote creation requested in Quotient unchecked</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>$Record.Quote_creation_requested_in_Quotient__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </assignmentItems>
    </assignments>
    <decisions>
        <name>Is_the_Stage_Quote_Creation</name>
        <label>Is the Stage Quote Creation</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Quote_creation_requested_in_Quotient_unchecked</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>not Quote Creation</defaultConnectorLabel>
        <rules>
            <name>Yes</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.StageName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Quote Creation</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Quote_creation_requested_in_Quotient_checked</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <description>when the stage is Create Quote Quote creation requested in Quotient should be true, if the stage is not the Quote creation requested in Quotient means the check box should be unchecked</description>
    <environments>Default</environments>
    <interviewLabel>Enquiry : RTF : stage Create Quote {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Enquiry : RTF : stage Create Quote</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Is_the_Stage_Quote_Creation</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>StageName</field>
            <operator>IsChanged</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <object>Opportunity</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
